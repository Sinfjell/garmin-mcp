# Copy to .env (or export in your shell) if you want non-interactive login
# instead of running `garmin-mcp-auth` interactively.

# Garmin Connect email + password. Only needed for the initial login or if
# the cached token expires and you want the server to re-auth on its own
# (MFA accounts should use `garmin-mcp-auth` instead, since MFA needs a
# one-time interactive code).
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Where session tokens are cached after login. Defaults to ~/.garminconnect
# if unset — you normally don't need to set this.
GARMIN_TOKENS=
